# Astra Resilience Copilot - Environment Variables
# Copy this file to .env and configure as needed

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# NASA EONET API (No API key required - public API)
# EONET_API_URL=https://eonet.gsfc.nasa.gov/api/v3

# NASA FIRMS API Configuration
# FIRMS_API_KEY=your_firms_api_key_here
# FIRMS_USE_API=false

# Future API Keys (when needed)
# NASA_API_KEY=your_nasa_api_key_here

# Data Storage
# DATA_DIR=data/processed

# Logging
# LOG_LEVEL=INFO